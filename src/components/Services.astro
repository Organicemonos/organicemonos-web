---
// src/components/Services.astro

const servicesList = [
  {
    icon: "📊",
    title: "Revisoría Fiscal y Auditoría",
    description: "Evaluación objetiva, dictamen de estados financieros y auditorías integrales bajo normas internacionales de aseguramiento."
  },
  {
    icon: "📈",
    title: "Contabilidad Integral",
    description: "Gestión contable oportuna, elaboración de estados financieros y reportes bajo estándares NIIF."
  },
  {
    icon: "⚖️",
    title: "Gestión Tributaria Estratégica",
    description: "Planeación fiscal avanzada, preparación de impuestos y optimización legal de la carga tributaria."
  },
  {
    icon: "👥",
    title: "Gestión del Talento Humano",
    description: "Gestión integral de todo el ciclo de vida del colaborador: atracción, selección, contratación, nómina, desarrollo, bienestar y retiro seguro."
  },
  {
    icon: "🛡️",
    title: "Sistema de Gestión SG-SST",
    description: "Diseño, implementación, ejecución, seguimiento continuo y auditoría del Sistema de Gestión de Seguridad y Salud en el Trabajo."
  },
  {
    icon: "📝",
    title: "Declaración de Renta",
    description: "Asesoría especializada en renta para personas naturales y jurídicas con máxima precisión fiscal."
  },
  {
    icon: "🏛️",
    title: "Gestiones Ante Entidades Estatales",
    description: "Representación, atención de requerimientos y trámites especializados ante la UGPP, DIAN, Cámara de Comercio, Secretaría de Hacienda, Ministerios y demás entes de control."
  }
];
---

<section id="servicios" style="padding: 5rem 0 3rem 0;">
  <!-- CABECERA DE SERVICIOS CON ALTO CONTRASTE -->
  <div style="text-align: center; margin-bottom: 3.5rem;">
    <span style="font-size: 0.9rem; font-weight: 800; letter-spacing: 0.12em; color: #60a5fa; text-transform: uppercase; display: inline-block; background: rgba(37, 99, 235, 0.2); padding: 0.4rem 1rem; border-radius: 50px; border: 1px solid rgba(96, 165, 250, 0.3); margin-bottom: 0.8rem;">
      ESPECIALIDADES INTEGRALES
    </span>
    <h2 style="font-size: 2.5rem; font-weight: 800; color: #ffffff; margin-top: 0.5rem; margin-bottom: 1rem; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">
      Nuestros Servicios Corporativos
    </h2>
    <p style="color: #f1f5f9; max-width: 680px; margin: 0 auto; font-size: 1.1rem; line-height: 1.6; font-weight: 500; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">
      Acompañamiento especializado en el desarrollo, cumplimiento normativo y crecimiento sostenible de tu empresa.
    </p>
  </div>

  <!-- GRILLA DE TARJETAS DE SERVICIOS -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.8rem;">
    {servicesList.map((service) => (
      <div 
        style="background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.18); padding: 2rem; border-radius: 1.25rem; box-shadow: 0 10px 30px rgba(0,0,0,0.3); transition: transform 0.25s ease, border-color 0.25s ease;"
        onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='rgba(96, 165, 250, 0.6)';"
        onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255, 255, 255, 0.18)';"
      >
        <div style="font-size: 2.5rem; margin-bottom: 1rem; display: inline-block; background: rgba(30, 41, 59, 0.9); padding: 0.6rem 0.8rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.15);">
          {service.icon}
        </div>
        <h3 style="color: #ffffff; font-size: 1.3rem; font-weight: 700; margin-top: 0; margin-bottom: 0.75rem; line-height: 1.3;">
          {service.title}
        </h3>
        <p style="color: #e2e8f0; font-size: 0.98rem; line-height: 1.65; margin: 0; font-weight: 400;">
          {service.description}
        </p>
      </div>
    ))}
  </div>
</section>