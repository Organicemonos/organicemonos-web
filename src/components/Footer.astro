---
const currentYear = new Date().getFullYear();
---

<footer style="border-top: 1px solid rgba(255, 255, 255, 0.1); padding: 3rem 1rem; margin-top: 4rem; background-color: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); color: #94a3b8; font-size: 0.95rem;">
  <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1.5rem;">
    <div>
      <h3 style="color: #ffffff; font-size: 1.25rem; font-weight: 800; margin-bottom: 0.25rem;">Organicémonos SAS</h3>
      <p style="margin: 0; color: #64748b;">Soluciones empresariales integrales.</p>
    </div>

    <div style="display: flex; gap: 2rem;">
      <a href="#nosotros" style="color: #cbd5e1; text-decoration: none; font-weight: 500;">Nosotros</a>
      <a href="#servicios" style="color: #cbd5e1; text-decoration: none; font-weight: 500;">Servicios</a>
      <a href="#contacto" style="color: #cbd5e1; text-decoration: none; font-weight: 500;">Contacto</a>
    </div>

    <div>
      <p style="margin: 0;">&copy; {currentYear} Organicémonos SAS. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>