---
// src/components/ContactForm.astro
---

<section id="contacto" style="padding: 5rem 0 3rem 0; border-top: 1px solid rgba(255, 255, 255, 0.1);">
  <div style="max-width: 650px; margin: 0 auto; text-align: center;">
    <h2 style="font-size: 2.5rem; font-weight: 800; color: #ffffff; margin-bottom: 1rem;">
      ¿Listo para organizar y hacer crecer tu empresa?
    </h2>
    <p style="color: #cbd5e1; font-size: 1.05rem; margin-bottom: 2rem;">
      Déjanos tus datos o contáctanos directamente a través de nuestros canales oficiales:
    </p>

    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.5rem; margin-bottom: 2.5rem; font-size: 0.95rem;">
      <span style="color: #f1f5f9;">📞 Tel: <strong>315 916 2853</strong></span>
      <a href="https://wa.me/573159162853" target="_blank" style="color: #4ade80; text-decoration: none; font-weight: 600;">💬 Hablar por WhatsApp</a>
      <a href="mailto:info@organicemonos.com" style="color: #60a5fa; text-decoration: none; font-weight: 600;">✉️ info@organicemonos.com</a>
    </div>

    <!-- FORMULARIO DE CONTACTO -->
    <form style="display: flex; flex-direction: column; gap: 1.25rem; text-align: left;">
      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          Nombre completo / Empresa
        </label>
        <input 
          type="text" 
          placeholder="Ej. Ana María Gómez" 
          style="width: 100%; padding: 0.85rem 1rem; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box;" 
        />
      </div>

      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          Correo electrónico
        </label>
        <input 
          type="email" 
          placeholder="correo@empresa.com" 
          style="width: 100%; padding: 0.85rem 1rem; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box;" 
        />
      </div>

      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          Teléfono / Celular
        </label>
        <input 
          type="tel" 
          placeholder="+57 300 000 0000" 
          style="width: 100%; padding: 0.85rem 1rem; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box;" 
        />
      </div>

      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          ¿En qué servicio estás interesado?
        </label>
        <select style="width: 100%; padding: 0.85rem 1rem; background: #0f172a; border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box;">
          <option>Revisoría Fiscal y Auditoría</option>
          <option>Contabilidad Integral</option>
          <option>Gestión Tributaria Estratégica</option>
          <option>Gestión del Talento Humano</option>
          <option>Sistema de Gestión SG-SST</option>
          <option>Declaración de Renta</option>
          <!-- NUEVA OPCIÓN INCLUIDA -->
          <option>Gestiones Ante Entidades Estatales (UGPP, DIAN, etc.)</option>
          <option>Otro / Asesoría general</option>
        </select>
      </div>

      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          Mensaje
        </label>
        <textarea 
          rows="4" 
          placeholder="Cuéntanos brevemente qué necesita tu negocio..." 
          style="width: 100%; padding: 0.85rem 1rem; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box; resize: vertical;"
        ></textarea>
      </div>

      <button 
        type="submit" 
        style="background-color: #1d4ed8; color: #ffffff; font-weight: 700; font-size: 1.05rem; padding: 1rem; border: none; border-radius: 0.6rem; cursor: pointer; transition: background-color 0.2s; margin-top: 0.5rem;"
        onmouseover="this.style.backgroundColor='#1e40af';"
        onmouseout="this.style.backgroundColor='#1d4ed8';"
      >
        Enviar Mensaje
      </button>
    </form>
  </div>
</section>