---
// src/components/ContactForm.astro
---

<section id="contacto" style="padding: 5rem 0 3rem 0; border-top: 1px solid rgba(255, 255, 255, 0.1);">
  <div style="max-width: 800px; margin: 0 auto; text-align: center;">
    
    <h2 style="font-size: 2.5rem; font-weight: 800; color: #ffffff; margin-bottom: 0.8rem; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">
      ¿Listo para organizar y hacer crecer tu empresa?
    </h2>
    
    <p style="color: #cbd5e1; font-size: 1.05rem; margin-bottom: 2.5rem;">
      Déjanos tus datos o contáctanos directamente a través de nuestros canales oficiales:
    </p>

    <!-- CAJONES DE CONTACTO DIRECTO (Estilo cápsulas del inicio) -->
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; margin-bottom: 3rem;">
      
      <!-- CAJÓN Teléfono -->
      <a 
        href="tel:3159162853" 
        style="background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.18); color: #ffffff; padding: 0.85rem 1.4rem; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 0.98rem; display: flex; align-items: center; gap: 0.6rem; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: all 0.25s ease;"
        onmouseover="this.style.background='rgba(37, 99, 235, 0.35)'; this.style.borderColor='#60a5fa'; this.style.transform='translateY(-3px)';"
        onmouseout="this.style.background='rgba(15, 23, 42, 0.75)'; this.style.borderColor='rgba(255, 255, 255, 0.18)'; this.style.transform='translateY(0)';"
      >
        <span style="font-size: 1.2rem;">📞</span>
        <span>Tel: <strong style="color: #60a5fa;">315 916 2853</strong></span>
      </a>

      <!-- CAJÓN WhatsApp -->
      <a 
        href="https://wa.me/573159162853?text=%C2%A1Hola%20Organic%C3%A9monos%20SAS!%20Deseo%20solicitar%20informaci%C3%B3n%20sobre%20sus%20servicios%20empresariales." 
        target="_blank" 
        rel="noopener noreferrer"
        style="background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(12px); border: 1px solid rgba(37, 211, 102, 0.35); color: #ffffff; padding: 0.85rem 1.4rem; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 0.98rem; display: flex; align-items: center; gap: 0.6rem; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: all 0.25s ease;"
        onmouseover="this.style.background='rgba(37, 211, 102, 0.2)'; this.style.borderColor='#25D366'; this.style.transform='translateY(-3px)';"
        onmouseout="this.style.background='rgba(15, 23, 42, 0.75)'; this.style.borderColor='rgba(37, 211, 102, 0.35)'; this.style.transform='translateY(0)';"
      >
        <span style="font-size: 1.2rem;">💬</span>
        <span>WhatsApp: <strong style="color: #4ade80;">Escribir ahora</strong></span>
      </a>

      <!-- CAJÓN Correo -->
      <a 
        href="mailto:info@organicemonos.com" 
        style="background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.18); color: #ffffff; padding: 0.85rem 1.4rem; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 0.98rem; display: flex; align-items: center; gap: 0.6rem; box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: all 0.25s ease;"
        onmouseover="this.style.background='rgba(37, 99, 235, 0.35)'; this.style.borderColor='#60a5fa'; this.style.transform='translateY(-3px)';"
        onmouseout="this.style.background='rgba(15, 23, 42, 0.75)'; this.style.borderColor='rgba(255, 255, 255, 0.18)'; this.style.transform='translateY(0)';"
      >
        <span style="font-size: 1.2rem;">✉️</span>
        <span>Correo: <strong style="color: #60a5fa;">info@organicemonos.com</strong></span>
      </a>

    </div>

    <!-- FORMULARIO DE CONTACTO -->
    <form style="display: flex; flex-direction: column; gap: 1.25rem; text-align: left; max-width: 650px; margin: 0 auto; background: rgba(15, 23, 42, 0.65); padding: 2.2rem; border-radius: 1.25rem; border: 1px solid rgba(255, 255, 255, 0.12); box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          Nombre completo / Empresa
        </label>
        <input 
          type="text" 
          placeholder="Ej. Ana María Gómez" 
          style="width: 100%; padding: 0.85rem 1rem; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box;" 
        />
      </div>

      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          Correo electrónico
        </label>
        <input 
          type="email" 
          placeholder="correo@empresa.com" 
          style="width: 100%; padding: 0.85rem 1rem; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box;" 
        />
      </div>

      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          Teléfono / Celular
        </label>
        <input 
          type="tel" 
          placeholder="+57 300 000 0000" 
          style="width: 100%; padding: 0.85rem 1rem; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box;" 
        />
      </div>

      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          ¿En qué servicio estás interesado?
        </label>
        <select style="width: 100%; padding: 0.85rem 1rem; background: #0f172a; border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box;">
          <option>Revisoría Fiscal y Auditoría</option>
          <option>Contabilidad Integral</option>
          <option>Gestión Tributaria Estratégica</option>
          <option>Gestión del Talento Humano</option>
          <option>Sistema de Gestión SG-SST</option>
          <option>Declaración de Renta</option>
          <option>Gestiones Ante Entidades Estatales (UGPP, DIAN, etc.)</option>
          <option>Otro / Asesoría general</option>
        </select>
      </div>

      <div>
        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #cbd5e1; margin-bottom: 0.4rem;">
          Mensaje
        </label>
        <textarea 
          rows="4" 
          placeholder="Cuéntanos brevemente qué necesita tu negocio..." 
          style="width: 100%; padding: 0.85rem 1rem; background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 0.6rem; color: #ffffff; font-size: 0.95rem; box-sizing: border-box; resize: vertical;"
        ></textarea>
      </div>

      <button 
        type="submit" 
        style="background-color: #1d4ed8; color: #ffffff; font-weight: 700; font-size: 1.05rem; padding: 1rem; border: none; border-radius: 0.6rem; cursor: pointer; transition: background-color 0.2s; margin-top: 0.5rem;"
        onmouseover="this.style.backgroundColor='#1e40af';"
        onmouseout="this.style.backgroundColor='#1d4ed8';"
      >
        Enviar Mensaje
      </button>
    </form>
  </div>
</section>