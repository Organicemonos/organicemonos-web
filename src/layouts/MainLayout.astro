---
// src/layouts/MainLayout.astro
const {
  title = "Organicémonos SAS | Consultoría Empresarial, SG-SST, RRHH y Revisoría Fiscal",
  description = "Firma consultora especializada en Revisoría Fiscal, Auditoría, Contabilidad, Gestión Tributaria, Recursos Humanos y SG-SST."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" style="background-color: #030712;">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css" />

  <!-- SCHEMA ORGANIZACIONAL SEO PARA MOTOR DE BÚSQUEDA -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "ConsultingService",
    "name": "Organicémonos SAS",
    "image": "http://localhost:4321/logo-organicemonos.png",
    "telephone": "+573159162853",
    "email": "info@organicemonos.com",
    "url": "http://localhost:4321/",
    "description": "Firma consultora especializada en Revisoría Fiscal, Contabilidad, Gestión Tributaria, Gestión de Recursos Humanos y SG-SST.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bogotá",
      "addressCountry": "CO"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Servicios Corporativos Integrales",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Revisoría Fiscal y Auditoría Integral"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Sistema de Gestión SG-SST (Implementación y Seguimiento)"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Gestión de Recursos Humanos (Ciclo de Vida del Colaborador)"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Gestión Tributaria y Declaración de Renta"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Contabilidad bajo Estándares NIIF"
          }
        }
      ]
    }
  }
  </script>

  <style is:global>
    html, body {
      margin: 0;
      padding: 0;
      background-color: #030712 !important;
      color: #ffffff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }

    .dynamic-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 0;
      background: #030712;
      overflow: hidden;
      pointer-events: none;
    }

    .light-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(90px);
      opacity: 0.85;
      mix-blend-mode: screen;
    }

    .light-1 {
      width: 650px;
      height: 650px;
      background: #2563eb;
      top: -10%;
      left: -5%;
      animation: moveLight1 10s infinite ease-in-out alternate;
    }

    .light-2 {
      width: 700px;
      height: 700px;
      background: #0284c7;
      bottom: -10%;
      right: -5%;
      animation: moveLight2 14s infinite ease-in-out alternate;
    }

    .light-3 {
      width: 500px;
      height: 500px;
      background: #3b82f6;
      top: 35%;
      left: 25%;
      animation: moveLight3 12s infinite ease-in-out alternate;
    }

    @keyframes moveLight1 {
      0% { transform: translate(0px, 0px) scale(1); }
      50% { transform: translate(180px, 120px) scale(1.3); }
      100% { transform: translate(0px, 0px) scale(1); }
    }

    @keyframes moveLight2 {
      0% { transform: translate(0px, 0px) scale(1); }
      50% { transform: translate(-180px, -140px) scale(1.25); }
      100% { transform: translate(0px, 0px) scale(1); }
    }

    @keyframes moveLight3 {
      0% { transform: translate(0px, 0px) scale(0.9); }
      50% { transform: translate(-120px, 100px) scale(1.2); }
      100% { transform: translate(0px, 0px) scale(0.9); }
    }

    .grid-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 1;
      background-image: radial-gradient(rgba(255, 255, 255, 0.15) 1px, transparent 0);
      background-size: 36px 36px;
      opacity: 0.4;
      pointer-events: none;
    }

    .page-content {
      position: relative;
      z-index: 2;
    }
  </style>
</head>

<body>

  <div class="dynamic-bg">
    <div class="light-orb light-1"></div>
    <div class="light-orb light-2"></div>
    <div class="light-orb light-3"></div>
  </div>
  <div class="grid-overlay"></div>

  <div class="page-content">
    <slot />
  </div>

  <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script is:inline>
    AOS.init({
      duration: 800,
      once: true,
      easing: 'ease-out-quad',
    });
  </script>
</body>
</html>