---
// src/layouts/MainLayout.astro
interface Props {
  title: string;
}

const { title } = Props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Organicémonos SAS - Consultoría Empresarial, SG-SST, RRHH y Revisoría Fiscal" />
    <meta name="viewport" content="width=device-width" />
    
    <!-- FAVICON (Logo de la pestaña del navegador) -->
    <link rel="icon" type="image/png" href="/logo-organicemonos.png" />
    
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Fuentes Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body style="margin: 0; padding: 0; background-color: #0b1329; color: #f8fafc; font-family: 'Plus Jakarta Sans', sans-serif;">
    <slot />
  </body>
</html>