---
// src/pages/index.astro
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Organicémonos SAS | Consultoría Empresarial, SG-SST, RRHH y Revisoría Fiscal</title>
  </head>
  <body class="bg-slate-900 text-slate-100 font-sans antialiased">

    <!-- BARRA DE NAVEGACIÓN -->
    <header class="sticky top-0 z-50 bg-slate-900/90 backdrop-blur-md border-b border-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <a href="#" class="flex items-center gap-3">
          <span class="text-2xl font-black tracking-tight text-white">
            Organicémonos <span class="text-blue-500">SAS</span>
          </span>
        </a>
        <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
          <a href="#nosotros" class="hover:text-blue-400 transition-colors">Nosotros</a>
          <a href="#servicios" class="hover:text-blue-400 transition-colors">Servicios</a>
          <a href="#contacto" class="hover:text-blue-400 transition-colors">Contacto</a>
        </nav>
        <div class="flex items-center gap-4">
          <a href="tel:3159162853" class="hidden sm:flex items-center gap-2 text-sm text-slate-300 hover:text-white">
            📞 315 916 2853
          </a>
          <a href="#contacto" class="bg-blue-600 hover:bg-blue-500 text-white font-semibold text-sm px-4 py-2 rounded-lg transition-all">
            Solicitar asesoría
          </a>
        </div>
      </div>
    </header>

    <!-- HERO SECTION -->
    <section class="relative py-20 lg:py-32 overflow-hidden bg-gradient-to-b from-slate-900 via-slate-800 to-slate-900">
      <div class="max-w-5xl mx-auto px-4 text-center">
        <h1 class="text-4xl sm:text-6xl font-extrabold text-white tracking-tight leading-tight mb-6">
          Soluciones corporativas que brindan <span class="text-blue-400">seguridad y resultados</span> a tu empresa
        </h1>
        <p class="text-lg sm:text-xl text-slate-300 mb-8 max-w-3xl mx-auto">
          Acompañamiento contable, legal, tributario y de gestión humana diseñado para proteger tu negocio y potenciar su crecimiento.
        </p>
        
        <!-- BADGES -->
        <div class="flex flex-wrap justify-center gap-3 mb-10 text-xs sm:text-sm text-slate-300">
          <span class="bg-slate-800/80 border border-slate-700 px-3 py-1.5 rounded-full">📊 Revisoría Fiscal & Auditoría</span>
          <span class="bg-slate-800/80 border border-slate-700 px-3 py-1.5 rounded-full">📈 Contabilidad Integral</span>
          <span class="bg-slate-800/80 border border-slate-700 px-3 py-1.5 rounded-full">⚖️ Gestión Tributaria</span>
          <span class="bg-slate-800/80 border border-slate-700 px-3 py-1.5 rounded-full">👥 Gestión del Talento Humano</span>
          <span class="bg-slate-800/80 border border-slate-700 px-3 py-1.5 rounded-full">🛡️ SG-SST</span>
          <span class="bg-slate-800/80 border border-slate-700 px-3 py-1.5 rounded-full">📝 Declaración de Renta</span>
          <span class="bg-slate-800/80 border border-slate-700 px-3 py-1.5 rounded-full">🏛️ Gestiones Estatales</span>
        </div>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="#contacto" class="bg-blue-600 hover:bg-blue-500 text-white font-bold px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-blue-500/25">
            Solicitar asesoría
          </a>
          <a href="#nosotros" class="bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-200 font-semibold px-8 py-3.5 rounded-xl transition-all">
            Conocer Organicémonos SAS
          </a>
        </div>
      </div>
    </section>

    <!-- SECCIÓN SERVICIOS -->
    <section id="servicios" class="py-20 bg-slate-900 border-t border-slate-800">
      <div class="max-w-6xl mx-auto px-4">
        <p class="text-xs font-bold tracking-widest text-blue-400 uppercase text-center mb-2">
          ESPECIALIDADES INTEGRALES
        </p>
        <h2 class="text-3xl sm:text-4xl font-bold text-center text-white mb-4">
          Nuestros Servicios Corporativos
        </h2>
        <p class="text-slate-400 text-center mb-16 max-w-2xl mx-auto">
          Acompañamiento especializado en el desarrollo, cumplimiento normativo y crecimiento sostenible de tu empresa.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Servicio 1 -->
          <div class="p-6 bg-slate-800/60 rounded-2xl border border-slate-700/60 hover:border-blue-500/50 transition-all">
            <h3 class="text-xl font-bold text-white mb-3">Revisoría Fiscal y Auditoría</h3>
            <p class="text-slate-300 text-sm leading-relaxed">
              Evaluación objetiva, dictamen de estados financieros y auditorías integrales bajo normas internacionales de aseguramiento.
            </p>
          </div>

          <!-- Servicio 2 -->
          <div class="p-6 bg-slate-800/60 rounded-2xl border border-slate-700/60 hover:border-blue-500/50 transition-all">
            <h3 class="text-xl font-bold text-white mb-3">Contabilidad Integral</h3>
            <p class="text-slate-300 text-sm leading-relaxed">
              Gestión contable oportuna, elaboración de estados financieros y reportes bajo estándares NIIF.
            </p>
          </div>

          <!-- Servicio 3 -->
          <div class="p-6 bg-slate-800/60 rounded-2xl border border-slate-700/60 hover:border-blue-500/50 transition-all">
            <h3 class="text-xl font-bold text-white mb-3">Gestión Tributaria Estratégica</h3>
            <p class="text-slate-300 text-sm leading-relaxed">
              Planeación fiscal avanzada, preparación de impuestos y optimización legal de la carga tributaria.
            </p>
          </div>

          <!-- Servicio 4 -->
          <div class="p-6 bg-slate-800/60 rounded-2xl border border-slate-700/60 hover:border-blue-500/50 transition-all">
            <h3 class="text-xl font-bold text-white mb-3">Gestión del Talento Humano</h3>
            <p class="text-slate-300 text-sm leading-relaxed">
              Gestión integral de todo el ciclo de vida del colaborador: atracción, selección, contratación, nómina, desarrollo, bienestar y retiro seguro.
            </p>
          </div>

          <!-- Servicio 5 -->
          <div class="p-6 bg-slate-800/60 rounded-2xl border border-slate-700/60 hover:border-blue-500/50 transition-all">
            <h3 class="text-xl font-bold text-white mb-3">Sistema de Gestión SG-SST</h3>
            <p class="text-slate-300 text-sm leading-relaxed">
              Diseño, implementación, ejecución, seguimiento continuo y auditoría del Sistema de Gestión de Seguridad y Salud en el Trabajo bajo la normatividad vigente.
            </p>
          </div>

          <!-- Servicio 6 -->
          <div class="p-6 bg-slate-800/60 rounded-2xl border border-slate-700/60 hover:border-blue-500/50 transition-all">
            <h3 class="text-xl font-bold text-white mb-3">Declaración de Renta</h3>
            <p class="text-slate-300 text-sm leading-relaxed">
              Asesoría especializada en renta para personas naturales y jurídicas con máxima precisión fiscal.
            </p>
          </div>

          <!-- Servicio 7 -->
          <div class="p-6 bg-slate-800/60 rounded-2xl border border-slate-700/60 hover:border-blue-500/50 transition-all md:col-span-2 lg:col-span-1">
            <h3 class="text-xl font-bold text-white mb-3">Gestiones Ante Entidades Estatales</h3>
            <p class="text-slate-300 text-sm leading-relaxed">
              Representación, atención de requerimientos y trámites especializados ante la UGPP, DIAN, Cámara de Comercio, Secretaría de Hacienda, Ministerios y demás entes de control.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN CONTACTO -->
    <section id="contacto" class="py-20 bg-slate-800/40 border-t border-slate-800">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">¿Listo para organizar y hacer crecer tu empresa?</h2>
        <p class="text-slate-300 mb-8">
          Déjanos tus datos o contáctanos directamente a través de nuestros canales oficiales:
        </p>

        <div class="flex flex-wrap justify-center items-center gap-6 mb-12">
          <span class="text-slate-200">📞 Tel: <strong>315 916 2853</strong></span>
          <a href="https://wa.me/573159162853" target="_blank" class="text-emerald-400 hover:underline">💬 Hablar por WhatsApp</a>
          <a href="mailto:info@organicemonos.com" class="text-blue-400 hover:underline">✉️ info@organicemonos.com</a>
        </div>

        <form class="space-y-4 max-w-xl mx-auto text-left">
          <div>
            <label class="block text-xs font-semibold text-slate-300 mb-1">Nombre completo / Empresa</label>
            <input type="text" placeholder="Ej. Ana María Gómez" class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-300 mb-1">Correo electrónico</label>
            <input type="email" placeholder="correo@empresa.com" class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-300 mb-1">Teléfono</label>
            <input type="tel" placeholder="+57 300 000 0000" class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-300 mb-1">¿En qué servicio estás interesado?</label>
            <select class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white focus:outline-none focus:border-blue-500">
              <option>Revisoría Fiscal y Auditoría</option>
              <option>Contabilidad Integral</option>
              <option>Gestión Tributaria Estratégica</option>
              <option>Gestión del Talento Humano</option>
              <option>Implementación y Seguimiento SG-SST</option>
              <option>Declaración de Renta</option>
              <option>Gestiones Ante Entidades Estatales (UGPP, DIAN, etc.)</option>
              <option>Otro / Asesoría general</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-300 mb-1">Mensaje</label>
            <textarea rows="4" placeholder="Cuéntanos brevemente qué necesita tu negocio..." class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded-lg text-white focus:outline-none focus:border-blue-500"></textarea>
          </div>
          <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3.5 rounded-lg transition-all">
            Enviar Mensaje
          </button>
        </form>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="py-8 bg-slate-950 border-t border-slate-800 text-center text-slate-500 text-sm">
      <p>© 2026 Organicémonos SAS. Todos los derechos reservados.</p>
    </footer>

  </body>
</html>